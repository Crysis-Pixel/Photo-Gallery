{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Photo Gallery",
  "version": "0.1.0",
  "identifier": "com.belfordblaze.photo-gallery",
  "build": {
  "beforeDevCommand": "npm run dev",
  "beforeBuildCommand": "npm run build",
  "frontendDist": "../dist",
  "devUrl": "http://localhost:5173"
},
  "app": {
    "windows": [
      {
        "title": "Photo Gallery",
        "width": 1280,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "externalBin": ["binaries/photo-gallery-backend"],
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
